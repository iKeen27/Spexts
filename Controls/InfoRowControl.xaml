<UserControl x:Class="Spexts.Controls.InfoRowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:Spexts.Helpers">
    <!--
        Reusable Hover-to-Copy Row
        DataContext is expected to be Spexts.Models.InfoRow
        • Label on left (secondary text)
        • Value on right (primary text, color-coded via ValueColor)
        • Copy button appears on hover
    -->

    <UserControl.Resources>
        <helpers:NullToDefaultColorConverter x:Key="ValueColorConverter"/>
    </UserControl.Resources>

    <Border x:Name="RowBorder" Padding="16,9" CornerRadius="5">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="Transparent"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#1F2937"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="155"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Label -->
            <TextBlock Grid.Column="0"
                       Text="{Binding Label}"
                       Foreground="#8B949E"
                       FontFamily="Segoe UI Variable, Segoe UI"
                       FontSize="13"
                       VerticalAlignment="Center"
                       Margin="0,0,20,0"/>

            <!-- Value (color-coded via ValueColor property) -->
            <TextBlock Grid.Column="1"
                       Text="{Binding Value}"
                       Foreground="{Binding ValueColor, Converter={StaticResource ValueColorConverter}}"
                       FontFamily="Segoe UI Variable, Segoe UI"
                       FontSize="13"
                       FontWeight="Medium"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"/>

            <!-- Copy Button (hidden until hover) -->
            <Button Grid.Column="2"
                    Command="{Binding CopyCommand}"
                    Style="{StaticResource CopyButtonStyle}"
                    Margin="8,0,0,0">
                <Button.Visibility>
                    <Binding Path="IsMouseOver" ElementName="RowBorder">
                        <Binding.Converter>
                            <BooleanToVisibilityConverter/>
                        </Binding.Converter>
                    </Binding>
                </Button.Visibility>
            </Button>
        </Grid>
    </Border>
</UserControl>
